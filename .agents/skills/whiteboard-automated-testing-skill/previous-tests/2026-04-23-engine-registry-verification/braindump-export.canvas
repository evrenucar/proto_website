{
  "nodes": [
    {
      "id": "cosmo-title",
      "x": 120,
      "y": 80,
      "width": 760,
      "height": 140,
      "type": "text",
      "text": "Cosmoboard\nFile-first. Local-first.\nStarter board for evrenucar.com."
    },
    {
      "id": "cosmo-boards",
      "x": 120,
      "y": 260,
      "width": 360,
      "height": 170,
      "type": "text",
      "text": "Boards\nThe canvas file is the board.\nEdit `content/boards/cosmoboard/current.canvas` locally first, then rebuild and ship."
    },
    {
      "id": "cosmo-markdown",
      "x": 520,
      "y": 260,
      "width": 360,
      "height": 170,
      "type": "text",
      "text": "Markdown\nKeep notes compact and scannable.\nUse short headings, bullets, and links inside text nodes."
    },
    {
      "id": "cosmo-bases",
      "x": 120,
      "y": 470,
      "width": 360,
      "height": 170,
      "type": "text",
      "text": "Bases\nThese are the stable anchors.\nThink folders, source files, and reference docs that the board points back to."
    },
    {
      "id": "cosmo-embeds",
      "x": 520,
      "y": 470,
      "width": 360,
      "height": 170,
      "type": "text",
      "text": "Embeds\nUse embeds for live media or external references.\nPrefer links when plain text is enough."
    },
    {
      "id": "cosmo-github",
      "x": 320,
      "y": 690,
      "width": 520,
      "height": 180,
      "type": "link",
      "url": "https://github.com/evrenucar/proto_website",
      "title": "GitHub mirror",
      "description": "Remote review and publish layer. Keep the working copy here on disk, then push the board file when it is ready."
    },
