476483856231 224.16625006236083 L -738.5716218311994 224.16625006236083 L -710.8329241843717 224.16625006236083 L -691.0195687223519 224.16625006236083 L -679.1315554451401 236.05426333957269 L -679.1315554451401 255.86761880159247 L -679.1315554451401 283.60631644842016 L -679.1315554451401 311.34501409524785 L -683.094226537544 331.15836955726763 L -687.0568976299479 347.00905392688344 L -687.0568976299479 374.7477515737111 L -694.9822398147559 402.4864492205388 L -694.9822398147559 430.2251468673665 L -694.9822398147559 450.03850232938623 L -694.9822398147559 465.8891866990021 L -694.9822398147559 485.7025421610218 L -694.9822398147559 505.5158976230416 L -671.2062132603321 505.5158976230416 L -635.5421734286965 505.5158976230416 L -607.8034757818689 501.5532265306377 L -572.1394359502333 493.6278843458298 L -552.3260804882135 489.6652132534258 L -516.6620406565779 473.81452888381 L -488.9233430097502 473.81452888381 L -469.10998754773044 465.8891866990021 L -449.29663208571066 465.8891866990021 L -429.48327662369087 465.8891866990021 L -405.70725006926716 465.8891866990021 L -393.8192367920553 477.7771999762139 L -385.8938946072474 493.6278843458298 L -374.0058813300355 521.3665819926574 L -350.2298547756118 553.0679507318891\" fill=\"none\" stroke=\"#3fdaca\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg>",
