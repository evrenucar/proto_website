    {
      "id": "kxw23744hpq",
      "x": -2651.654668986006,
      "y": 217.86785360319013,
      "width": 367.2769154051707,
      "height": 112.60894110252306,
      "text": "<svg class=\"bd-drawing\" viewBox=\"-2651.654668986006 217.86785360319013 367.2769154051707 112.60894110252306\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"none\" style=\"overflow:visible; display:block;\"><path d=\"M -2646.654668986006 222.86785360319013 L -2639.2371551713654 225.3403582080702 L -2618.220866029885 225.3403582080702 L -2587.314558468884 225.3403582080702 L -2552.699494000563 226.57661051051025 L -2524.265691044442 231.5216197202704 L -2498.3043926932014 235.2303766275905 L -2483.469365063921 237.70288123247056 L -2472.3430943419608 237.70288123247056 L -2466.1618328297604 240.17538583735063 L -2466.1618328297604 251.30165655931097 L -2466.1618328297604 257.48291807151116 L -2466.1618328297604 266.1366841885914 L -2466.1618328297604 274.7904503056717 L -2466.1618328297604 287.15297333007203 L -2466.1618328297604 298.27924405203237 L -2466.1618328297604 309.4055147739927 L -2466.1618328297604 318.059280891073 L -2463.6893282248802 324.24054240327314 L -2451.32680520048 325.4767947057132 L -2434.0192729663195 319.295533193513 L -2414.2392361272787 311.8780193788728 L -2388.277937776038 310.64176707643276 L -2358.6078825174773 308.1692624715527 L -2332.6465841662366 305.6967578666726 L -2310.3940427223156 305.6967578666726 L -2295.559015093035 305.6967578666726 L -2289.3777535808354 305.6967578666726\" fill=\"none\" stroke=\"#3fdaca\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg>",
