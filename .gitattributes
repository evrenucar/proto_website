# Default: detect text, store as LF in repo and working tree.
# Overrides core.autocrlf for any text file Git recognizes.
* text=auto eol=lf

# Source code
*.js    text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.ts    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.xml   text eol=lf
*.svg   text eol=lf

# Obsidian canvas (JSON) and markdown content
*.canvas  text eol=lf

# Shell scripts MUST be LF (break otherwise on Linux/macOS/CI)
*.sh    text eol=lf

# Windows batch files MUST be CRLF (break otherwise on Windows)
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary files — never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.mp3   binary
*.mp4   binary
*.webm  binary
*.heapsnapshot binary
